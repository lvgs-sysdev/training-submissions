{
  "inputs": [
    {
      "type": "promptString",
      "id": "figma-api-key",
      "description": "Figma Personal Access Token",
      "password": true
    }
  ],
  "servers": {
    "figmaMcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--stdio"],
      "env": {
        "FIGMA_API_KEY": "${input:figma-api-key}"
      }
    }
  }
}
