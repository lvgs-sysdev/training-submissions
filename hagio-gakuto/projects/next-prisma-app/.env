# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/next_prisma"

## PostgreSQLコンテナが起動時に使用するユーザー、パスワード、DB名
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb

# Prismaが、上記で作成されたDBコンテナに接続するためのURL
# USERとPASSWORDは上のものと一致させ、ホスト名は'db'にする
DATABASE_URL="postgresql://myuser:mypassword@db:5432/mydb?schema=public"

