generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  avatar_url    String?
  is_deleted    Boolean  @default(false)
  createdAt DateTime @default(now())
  favorites Favorite[]
  inquiries Inquiry[]
}

model Favorite {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  // Userへのリレーション
  user       User     @relation(fields: [userId], references: [id])
  userId     Int

  property       Property     @relation(fields: [propertyId], references: [id])
  propertyId String

  // ユーザーIDと物件IDの組み合わせはユニークでなければならない
  @@unique([userId, propertyId])
}


model Inquiry {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  // Userへのリレーション
  user       User     @relation(fields: [userId], references: [id])
  userId     Int

  property       Property     @relation(fields: [propertyId], references: [id])
  propertyId String

  // ユーザーIDと物件IDの組み合わせはユニークでなければならない
  @@unique([userId, propertyId])
}

model Property {
  id               String   @id @db.VarChar(100)
  name             String   @db.VarChar(200)
  type             String   @db.VarChar(50)
  price_rent       Int
  zip              String   @db.VarChar(10)
  prefecture       String   @db.VarChar(10)
  city             String   @db.VarChar(20)
  street           String   @db.VarChar(50)
  block            String   @db.VarChar(20)
  lat              Decimal  @db.Decimal(10, 6)
  lng              Decimal  @db.Decimal(10, 6)
  nearest_station  String   @db.VarChar(100)
  area_sqm         Decimal  @db.Decimal(5, 1)
  layout           String   @db.VarChar(10)
  age_years        Int
  floor            Int
  total_floors     Int
  features         String   @db.Text
  photos           String   @db.Text
  floor_plan_url   String   @db.VarChar(200)

  favorites        Favorite[]
  inquiries        Inquiry[]
}