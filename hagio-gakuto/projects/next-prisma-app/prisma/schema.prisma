generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  avatar_url    String?
  is_deleted    Boolean  @default(false)
  created_at DateTime @default(now())
  role     Int @default(1) 
  favorites Favorite[]
  inquiries Inquiry[]
}

model Favorite {
  id         Int      @id @default(autoincrement())
  created_at  DateTime @default(now())

  // Userへのリレーション
  user       User     @relation(fields: [user_id], references: [id])
  user_id     Int

  property       Property     @relation(fields: [property_id], references: [id])
  property_id Int

  // ユーザーIDと物件IDの組み合わせはユニークでなければならない
  @@unique([user_id, property_id])
}


model Inquiry {
  id         Int      @id @default(autoincrement())
  created_at  DateTime @default(now())

  // Userへのリレーション
  user       User     @relation(fields: [user_id], references: [id])
  user_id     Int

  property       Property     @relation(fields: [property_id], references: [id])
  property_id Int

  // ユーザーIDと物件IDの組み合わせはユニークでなければならない
  @@unique([user_id, property_id])
}

model Property {
  id               Int @id @default(autoincrement())
  name             String   
  type             String   
  price_rent       Int
  zip              String   
  prefecture       String   
  city             String  
  street           String   
  block            String   
  lat              Decimal  
  lng              Decimal  
  nearest_station  String   
  walk_to_station  Int 
  area_sqm         Decimal  
  layout           String   
  age_years        Int
  floor            Int
  total_floors     Int
  floor_plan_url   String   

  favorites        Favorite[]
  inquiries        Inquiry[]
  propertyImages   PropertyImage[]
  propertyFeature   PropertyFeature[]
}


model PropertyImage {
  id         Int    @id @default(autoincrement())
  image_url String

  property       Property     @relation(fields: [property_id], references: [id])
  property_id Int
}

model PropertyFeature {
  id         Int    @id @default(autoincrement())
  feature String

  property       Property     @relation(fields: [property_id], references: [id])
  property_id Int
}