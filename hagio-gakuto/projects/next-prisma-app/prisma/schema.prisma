generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//================================================================
//  ユーザー
//================================================================
model User {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(15)
  email     String    @unique @db.VarChar(254)
  password  String    @db.VarChar(255)
  avatarUrl String?   @map("avatar_url") @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  role   Role @relation(fields: [roleId], references: [id])
  roleId Int  @default(1) @map("role_id") // 1: General User

  favorites Favorite[]
  inquiries Inquiry[]
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50) // ロール名はユニークに
  users User[]
}

//================================================================
//  物件関連
//================================================================

/// 建物の情報を格納するモデル
model Building {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(100)
  zipCode        String   @map("zip_code") @db.VarChar(10)
  prefecture     String   @db.VarChar(10)
  city           String   @db.VarChar(20)
  town           String   @db.VarChar(50)
  chome          String?  @db.VarChar(50)
  block          String   @db.VarChar(100)
  nearestStation String   @map("nearest_station") @db.VarChar(100)
  walkToStation  Int      @map("walk_to_station")
  buildDate      DateTime @map("build_date") @db.Date
  totalFloors    Int      @map("total_floors")

  propertyType   PropertyType @relation(fields: [propertyTypeId], references: [id])
  propertyTypeId Int          @map("property_type_id")

  units  Unit[]
  images Image[]
}

/// 部屋（貸出単位）の情報を格納するモデル
model Unit {
  id         Int     @id @default(autoincrement())
  priceRent  Int     @map("price_rent")
  areaSqm    Decimal @map("area_sqm")
  floor      Int
  roomNumber String? @map("room_number") @db.VarChar(10)
  isEmpty    Boolean @map("is_empty") @default(true)

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId Int      @map("building_id")

  layout   Layout @relation(fields: [layoutId], references: [id])
  layoutId Int    @map("layout_id")

  images       Image[]
  unitFeatures UnitFeature[]
  favorites    Favorite[]
  inquiries    Inquiry[]
}

/// 物件の画像を管理するモデル
model Image {
  id         Int    @id @default(autoincrement())
  imageUrl   String @map("image_url") @db.VarChar(255)

  category   ImageCategory @relation(fields: [categoryId], references: [id])
  categoryId Int           @map("category_id")

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId Int      @map("building_id")

  unit   Unit? @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId Int?  @map("unit_id")
}

/// 画像カテゴリのマスタテーブル
model ImageCategory {
  id     Int     @id @default(autoincrement())
  name   String  @unique @db.VarChar(50)
  images Image[]
}

/// 物件種別（例: マンション、アパート、一軒家）
model PropertyType {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(50)
  buildings Building[]
}

/// 間取り（例: 1LDK, 2DK）
model Layout {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)
  units Unit[]
}

/// 物件の特徴（例: ペット可、オートロック）
model Feature {
  id           Int           @id @default(autoincrement())
  name         String        @unique @db.VarChar(30)
  unitFeatures UnitFeature[]
}

/// UnitとFeatureの中間テーブル（多対多）
model UnitFeature {
  unit   Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId Int  @map("unit_id")

  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  featureId Int     @map("feature_id")

  @@id([unitId, featureId])
}

//================================================================
//  ユーザーアクティビティ
//================================================================
model Favorite {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")

  unit   Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId Int  @map("unit_id")

  @@unique([userId, unitId])
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")

  unit   Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId Int  @map("unit_id")

  inquiryCategory   InquiryCategory @relation(fields: [inquiryCategoryId], references: [id])
  inquiryCategoryId Int             @map("inquiry_category_id")
}

/// 問い合わせカテゴリのマスタテーブル
model InquiryCategory {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(30) 
  inquiries Inquiry[] 
}


//================================================================
//  その他ビジネスロジック
//================================================================
model Workplace {
  id                     Int                    @id @default(autoincrement())
  name                   String                 @unique @db.VarChar(50)
  rentAllowanceAddresses RentAllowanceAddress[]
}

model RentAllowanceAddress {
  id          Int     @id @default(autoincrement())
  prefecture  String  @db.VarChar(10)
  city        String  @db.VarChar(20)
  town        String  @db.VarChar(50)
  chome       String? @db.VarChar(50)

  workplace   Workplace @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  workplaceId Int       @map("workplace_id")
}