generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  avatar_url    String?
  is_deleted    Boolean  @default(false)
  createdAt DateTime @default(now())
  favorites Favorite[]
  Inquiries Inquiry[]
}

model Favorite {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  // Userへのリレーション
  user       User     @relation(fields: [userId], references: [id])
  userId     Int

  propertyId String

  // ユーザーIDと物件IDの組み合わせはユニークでなければならない
  @@unique([userId, propertyId])
}


model Inquiry {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  // Userへのリレーション
  user       User     @relation(fields: [userId], references: [id])
  userId     Int

  propertyId String

  // ユーザーIDと物件IDの組み合わせはユニークでなければならない
  @@unique([userId, propertyId])
}