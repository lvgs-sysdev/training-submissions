generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//================================================================
//  認証・ユーザー関連
//================================================================
model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(15)
  email     String   @unique @db.VarChar(254)
  password  String   @db.VarChar(255)
  avatarUrl String?  @map("avatar_url") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  role   Role @relation(fields: [roleId], references: [id])
  roleId Int  @default(1) @map("role_id")

  favorites Favorite[]
  inquiries Inquiry[]
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(50)
  users User[]
}

//================================================================
//  物件関連
//================================================================
model Property {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  priceRent       Int      @map("price_rent")
  zip             String   @db.VarChar(10)
  prefecture      String   @db.VarChar(10)
  city            String   @db.VarChar(20)
  town            String   @db.VarChar(50)
  chome           Int  
  block           Int   
  building        String?   @db.VarChar(100)
  nearestStation  String   @map("nearest_station") @db.VarChar(100)
  walkToStation   Int      @map("walk_to_station")
  areaSqm         Decimal  @map("area_sqm")
  buildDate       DateTime @map("build_date")
  floor           Int
  totalFloors     Int      @map("total_floors")
  floorPlanUrl    String   @map("floor_plan_url") @db.VarChar(100)
  roomNumber      String?  @map("room_number") @db.VarChar(20)
  isEmpty         Boolean? @map("is_empty")

  propertyType   PropertyType @relation(fields: [propertyTypeId], references: [id])
  propertyTypeId Int          @map("property_type_id")

  layout   Layout @relation(fields: [layoutId], references: [id])
  layoutId Int    @map("layout_id")

  features       Feature[]
  favorites      Favorite[]
  inquiries      Inquiry[]
  propertyImages PropertyImage[]
}

model PropertyType {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(50)
  properties Property[]
}

model Layout {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(50)
  properties Property[]
}

model PropertyImage {
  id         Int    @id @default(autoincrement())
  imageUrl   String @map("image_url") @db.VarChar(100)

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId Int      @map("property_id")
}

model Feature {
  id         Int        @id @default(autoincrement())
  name       String     @unique @db.VarChar(30)
  properties Property[]
}

model Favorite {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation(fields: [userId], references: [id])
  userId Int  @map("user_id")

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId Int      @map("property_id")

  @@unique([userId, propertyId])
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at") // ← 命名規則を修正

  user   User @relation(fields: [userId], references: [id])
  userId Int  @map("user_id")

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId Int      @map("property_id")

  @@unique([userId, propertyId])
}

model Workplace {
  id                     Int                    @id @default(autoincrement())
  name                   String                 @db.VarChar(50)
  rentAllowanceAddresses RentAllowanceAddress[]
}

model RentAllowanceAddress {
  id          Int       @id @default(autoincrement())
  prefecture  String    @db.VarChar(10)
  city            String   @db.VarChar(20)
  town            String   @db.VarChar(50)
  chome           Int

  workplace   Workplace @relation(fields: [workplaceId], references: [id])
  workplaceId Int       @map("workplace_id")
}