# --- データベース用 ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=my_app
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- バックエンドアプリケーション用 ---
DB_USER=${POSTGRES_USER}
DB_HOST=db
DB_NAME=${POSTGRES_DB}
DB_PASSWORD=${POSTGRES_PASSWORD}
DB_PORT=5432

# 認証
JWT_SECRET_KEY=aaa
JWT_EXPIRIES_TIME=3600


