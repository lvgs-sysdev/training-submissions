<style>
	/* メインとサイドの配置 */
	.container {
		display: flex;
		gap: 100px;
		padding: 200px 123px 100px 123px;
	}

	.main-content {
		flex: 3;
	}

	aside {
		flex: 1;
	}

	.main-content > *, aside > div {
		margin-bottom: 80px;
	}

	/* 投稿者プロフィールバー */
	.author-profile {
		height: 70px;
		margin-bottom: 100px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.author-profile p {
		margin: 0;
	}

	.profile-left {
		width: auto;
		height: 70px;
		display: flex;
		align-items: center;
		gap: 20px;
	}

	.profile-left p {
		margin: 10px 0;
	}

	.author-name {
		font-size: 16px;
	}

	.post-date {
		font-size: 14px;
		font-weight: 300;
		color: grey;
	}

	ul {
		padding-left: 0;
	}

	li {
		list-style: none;
		display: inline-block;
	}

	.profile-right li {
		margin-right: 10px;
	}

	/* 記事の調整 */
	h3 {
		font-size: 36px;
		margin-top: 0;
		margin-bottom: 48px;
	}

	article > p:not(p:first-child) {
		color: #757575;
		font-size: 18px;
		font-weight: 300;
		margin-bottom: 40px;
	}

	article a {
		padding: 10px 15px;
		color: #757575;
		border: 1px solid #757575;
	}

	/* 記事一覧 */
	.articles {
		display: flex;
		flex-wrap: wrap;
		gap: 20px;
	}

	.main-content .article {
		width: 420px;
		height: auto;
		margin-bottom: 60px;
	}

	.article h1 {
		font-weight: 300;
		font-size: 20px;
	}

	aside .article h1 {
		font-weight: 300;
		font-size: 18px;
	}

	.article p {
		font-weight: 300;
		font-size: 16px;
		color: #757575;
	}

	/* 著者のアイコン */
	.author {
		display: flex;
		column-gap: 20px;
		margin: 20px 0;
	}

	.author-karen-smith {
		width: 70px;
		height: 70px;
		border-radius: 50%;
		background-position: 70% 20%;
		background-size: 170%;
	}

	.author-andrea-wise {
		width: 70px;
		height: 70px;
		border-radius: 50%;
		background-position: 50% 30%;
		background-size: 300%;
	}

	.author-samantha-william {
		width: 70px;
		height: 70px;
		border-radius: 50%;
		background-position: 48% 15%;
		background-size: 280%;
	}

	.author-renata-hope {
		width: 70px;
		height: 70px;
		border-radius: 50%;
		background-position: 57% 18%;
		background-size: 500%;
	}

	.author-angela-saunder {
		width: 70px;
		height: 70px;
		border-radius: 50%;
		background-position: 42% 24%;
		background-size: 200%;
	}

	/* 画像の調整 */
	img {
		width: 100%;
		height: auto;
	}

	a img {
		aspect-ratio: 3 / 2;
		object-fit: cover;
	}

	a {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	/* 記事途中の2枚並んだ写真 */
	.two-pictures {
		display: flex;
		gap: 20px;
		align-items: flex-start;
	}

	.two-pictures img {
		width: 50%;
		max-height: 400px;
		object-fit: cover;
	}

	/* その他の書式 */
	h2 {
		margin-top: 0;
	}

	.tag {
		color: orangered;
		font-weight: 500;
	}

	.line{
		color: #DEDEDE;
	}

	.date {
		color: #757575;
		font-weight: 300;
	}

	@media screen and (max-width: 768px) {
		.container {
			flex-direction: column;
			gap: 0;
			padding: 200px 50px 100px 50px;
		}

		.main-content, aside {
			flex: auto;
		}

		aside .article {
			width: 420px;
		}

		.author-profile {
			flex-direction: column;
			align-items: flex-start;
		}

		.profile-right img {
			width: 37px;
		}

		.article {
			margin-bottom: 20px;
		}
	}
</style>