---
---
<header>
	<div class="container">
		<div class="header-left">
			<h1><a href="/">DAYDAYTRAVEL</a></h1>
		</div>

		<nav class="header-right">
			<ul>
				<li class="login"><a href="#">Login</a></li>
				<li class="get-started"><a href="#">Get started</a></li>
			</ul>
		</nav>
	</div>
</header>

<style>
	header {
		position: fixed;
		z-index: 1;
		width: 100%;
		height: 90px;
		background-color: #FFFFFF;
		border-bottom: 1px solid #DEDEDE;
	}

	.container {
		height: 100%;
		padding: 0 123px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.header-right ul {
		display: flex;
		align-items: center;
		gap: 32px;
	}

	.get-started a {
		display: block;
		padding: 10px 15px;
		background-color: #FF553C;
	}

	.header-right li {
		font-size: 1rem;
	}

	.header-left h1 {
		font-size: 1.25rem;
		color: #FF553C;
	}

	.login {
		color: #121212;
	}

	.get-started {
		color: #FFFFFF;
	}

	@media screen and (max-width:768px) {
		header {
			height: 70px;
		}
		
		.container {
			padding: 0 20px;
		}

		.header-left h1 {
			font-size: 1rem;
		}

		.header-right ul {
			gap: 20px;
		}

		.header-right li {
			font-size: 0.8rem;
		}

		.get-started a {
			padding: 10px 10px;
		}
	}
</style>