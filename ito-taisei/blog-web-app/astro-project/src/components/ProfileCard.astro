---

<aside class={styles.card}>
  <div class={styles.avatarBox}>
    <img
      class={styles.avatar}
      src={profile.avatarUrl || "/images/default-avatar.png"}
      alt={`${profile.name}のプロフィール画像`}
    />
  </div>
  <div class={styles.meta}>
    <div class={styles.metaRow}>
      <div class={styles.name}>{profile.name}</div>
      <div class={styles.date}>{profile.date}</div>
    </div>

    <div class={styles.snsWrapper}>
      {
        profile.sns &&
          profile.sns.map((social: SocialLink) => (
            <a
              class:list={[styles.snsLink, "profile-sns__link"]}
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.platform}
              title={social.platform}
            >
              {social.platform === "twitter" && (
                <Fragment set:html={twitterSvg} />
              )}
              {social.platform === "instagram" && (
                <Fragment set:html={instagramSvg} />
              )}
              {social.platform === "linkedin" && (
                <Fragment set:html={linkedinSvg} />
              )}
            </a>
          ))
      }

      <button
        type="button"
        class:list={[styles.copyButton, "profile-sns__copy-button"]}
        id="copy-link-button"
        aria-label="Copy page link"
        title="Copy page link"
      >
        <Fragment set:html={copyLinkSvg} />
      </button>
    </div>
  </div>
</aside>

<script>
  const copyButton = document.getElementById("copy-link-button");
  if (copyButton) {
    copyButton.addEventListener("click", () => {
      const url = window.location.href;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard
          .writeText(url)
          .then(() => console.log("Copied!"))
          .catch(() => console.error("Failed"));
      } else {
        const ta = document.createElement("textarea");
        ta.value = url;
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand("copy");
          console.log("Copied!");
        } catch (e) {
          console.error("Failed");
        }
        ta.remove();
      }
    });
  }
</script>
